generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  fullName         String?
  passwordHash     String?
  authProvider     String   @default("email")
  googleId         String?  @unique
  microsoftId      String?  @unique
  isDealer         Boolean  @default(false)
  pricePerLaborHour Float?
  logoUrl          String?
  originalLogoUrl  String?
  qrCodeUrl        String?
  maxScannerDevices Int?
  maxVins           Int?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  scans            Scan[]
  usedScannerDevices UserScannerDevice[]
  usedVins           UserVinUsage[]
  passwordResetTokens PasswordResetToken[]
  serviceAppointments ServiceAppointment[]
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([userId])
}

model Otp {
  id        String   @id @default(uuid())
  email     String
  code      String
  verified  Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email, code])
}

model Scan {
  id                   String     @id @default(uuid())
  userId               String
  user                 User       @relation(fields: [userId], references: [id])
  vin                  String
  mileage              Float?
  milOn                Boolean
  dtcCount             Int
  storedDtcCodes       String[]
  pendingDtcCodes      String[]
  permanentDtcCodes    String[]
  distanceSinceCleared Float?
  timeSinceCleared     Float?
  warmupsSinceCleared  Int?
  distanceWithMilOn    Float?
  fuelSystemStatus     Json?
  secondaryAirStatus   Int?
  milStatusByEcu       Json?
  stockNumber          String?
  additionalRepairs    String[]
  scannerDeviceId      String?
  userFullName         String?
  vehicleOwnerName     String?
  rawPayload           Json
  vehicleYear          Int?
  vehicleMake          String?
  vehicleModel         String?
  vehicleEngine        String?
  status               ScanStatus @default(RECEIVED)
  errorMessage         String?
  scanDate             DateTime
  receivedAt           DateTime   @default(now())
  processedAt          DateTime?
  fullReport           FullReport?

  @@index([userId])
  @@index([vin])
}

model FullReport {
  id                      String    @id @default(uuid())
  scanId                  String    @unique
  scan                    Scan      @relation(fields: [scanId], references: [id])
  aiRawResponse           Json
  dtcAnalysis             Json
  emissionsCheck          Json
  mileageRiskAssessment   Json
  repairRecommendations   Json
  modulesScanned          String[]
  datapointsScanned       Int
  totalReconditioningCost Float
  additionalRepairsCost   Float     @default(0)
  additionalRepairsData   Json?
  reportVersion           String
  pdfUrl                  String?
  pdfGeneratedAt          DateTime?
  emailSentAt             DateTime?
  createdAt               DateTime  @default(now())

  @@index([scanId])
}

model UserScannerDevice {
  id               String   @id @default(uuid())
  userId           String
  user             User     @relation(fields: [userId], references: [id])
  deviceId         String
  deviceName       String?
  scannerOwnerName String?
  firstUsedAt      DateTime @default(now())
  lastUsedAt       DateTime @default(now())

  @@unique([userId, deviceId])
  @@index([userId])
}

model UserVinUsage {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  vin        String
  firstUsedAt DateTime @default(now())
  lastUsedAt  DateTime @default(now())
  scanCount   Int      @default(1)

  @@unique([userId, vin])
  @@index([userId])
}

enum ScanStatus {
  RECEIVED
  DECODING_VIN
  ANALYZING
  GENERATING_PDF
  EMAILING
  COMPLETED
  FAILED
}

model Admin {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Appraisal {
  id            String   @id @default(uuid())
  userId        String
  vin           String
  vehicleYear   Int?
  vehicleMake   String?
  vehicleModel  String?
  vehicleTrim   String?
  mileage       Int?
  condition     String?
  zipCode       String?
  notes         String?
  valuationData Json?
  pdfUrl        String?
  photoCount    Int      @default(0)
  userEmail          String?
  userFullName       String?
  vehicleOwnerName   String?
  createdAt          DateTime @default(now())

  @@index([userId])
  @@index([vin])
}

model ServiceAppointment {
  id                 String    @id @default(uuid())
  userId             String
  user               User      @relation(fields: [userId], references: [id])
  name               String
  email              String
  phone              String?
  dealership         String?
  vehicle            String?
  vin                String?
  serviceType        String
  preferredDate      String
  preferredTime      String?
  additionalNotes    String?
  status             String    @default("pending")
  adminEmailSentAt   DateTime?
  userEmailSentAt    DateTime?
  emailLastError     String?
  emailAttempts      Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
}

model Inspection {
  id          String   @id @default(uuid())
  userId      String
  vehicleInfo String?
  vin         String?
  mileage     String?
  color       String?
  inspector   String?
  date        String
  ratings     Json
  damageMarks Json
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}
