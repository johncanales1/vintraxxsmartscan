# Resolve react_native_pods.rb with node to allow for hoisting
require Pod::Executable.execute_command('node', ['-p',
  'require.resolve(
    "react-native/scripts/react_native_pods.rb",
    {paths: [process.argv[1]]},
  )', __dir__]).strip

# GoogleMLKit 7.0+ (needed so MLKitCommon ~> 12/14 is used, which depends on
# GoogleUtilities ~> 8.0 and is compatible with GoogleSignIn 9.x) requires
# iOS 15.5, so we bump above the React Native default of 15.1.
platform :ios, '15.5'
prepare_react_native_project!

linkage = ENV['USE_FRAMEWORKS']
if linkage != nil
  Pod::UI.puts "Configuring Pod with #{linkage}ally linked Frameworks".green
  use_frameworks! :linkage => linkage.to_sym
end

use_modular_headers!

target 'VTSmartScan' do
  config = use_native_modules!

  use_react_native!(
    :path => config[:reactNativePath],
    # An absolute path to your application root.
    :app_path => "#{Pod::Config.instance.installation_root}/.."
  )

  # Pin GoogleMLKit subspecs so CocoaPods does not resolve the old
  # MLKitTextRecognitionChinese 1.0.0-beta1 (which drags in MLKitCommon 3.1.0
  # requiring GoogleUtilities ~> 7.0 and conflicts with GoogleSignIn 9.x that
  # needs GoogleUtilities ~> 8.0). GoogleMLKit 9.0.0 pulls in MLKitCommon
  # ~> 14.0 which uses GoogleUtilities ~> 8.0.
  pod 'GoogleMLKit/TextRecognition', '~> 9.0'
  pod 'GoogleMLKit/TextRecognitionChinese', '~> 9.0'
  pod 'GoogleMLKit/TextRecognitionDevanagari', '~> 9.0'
  pod 'GoogleMLKit/TextRecognitionJapanese', '~> 9.0'
  pod 'GoogleMLKit/TextRecognitionKorean', '~> 9.0'

  post_install do |installer|
    react_native_post_install(
      installer,
      config[:reactNativePath],
      :mac_catalyst_enabled => false,
      # :ccache_enabled => true
    )

    # Fix: React-jsitooling and React-RuntimeCore both live in the react_runtime/ public
    # headers directory and both originally use `umbrella header`. Clang only allows ONE
    # module to own a directory via umbrella, so we rewrite React-jsitooling.modulemap
    # to use a plain `header` (no directory ownership) and give it a unique module name.
    jsitooling_modulemap = File.join(
      installer.sandbox.root,
      'Headers/Public/react_runtime/React-jsitooling.modulemap'
    )
    if File.exist?(jsitooling_modulemap)
      content = File.read(jsitooling_modulemap)
      # Rewrite the whole file: rename module AND replace umbrella header with plain header
      # so it no longer competes with react_runtime for directory ownership.
      fixed = <<~MODULEMAP
        module react_jsitooling {
          header "React-jsitooling-umbrella.h"

          export *
        }
      MODULEMAP
      File.write(jsitooling_modulemap, fixed) unless content == fixed
    end

    # Fix: React-RuntimeApple and ReactCommon both live in the ReactCommon/ public headers
    # directory and both declare `module ReactCommon` with `umbrella header`. Rewrite
    # React-RuntimeApple.modulemap with a unique name and plain header (no directory ownership).
    runtime_apple_modulemap = File.join(
      installer.sandbox.root,
      'Headers/Public/ReactCommon/React-RuntimeApple.modulemap'
    )
    if File.exist?(runtime_apple_modulemap)
      content = File.read(runtime_apple_modulemap)
      fixed = <<~MODULEMAP
        module React_RuntimeApple {
          header "React-RuntimeApple-umbrella.h"

          export *
        }
      MODULEMAP
      File.write(runtime_apple_modulemap, fixed) unless content == fixed
    end

    # Fix: React-RuntimeHermes module conflict with React-RuntimeCore
    # Both declare umbrella module 'react_runtime', causing build failures in Xcode 15+
    # React-RuntimeHermes is in react_runtime_hermes directory, so rename its module
    hermes_modulemap = File.join(
      installer.sandbox.root,
      'Target Support Files/React-RuntimeHermes/React-RuntimeHermes.modulemap'
    )
    if File.exist?(hermes_modulemap)
      content = File.read(hermes_modulemap)
      if content.include?('module react_runtime {')
        File.write(hermes_modulemap, content.sub('module react_runtime {', 'module react_runtime_hermes {'))
      end
    end

    # Also update React-RuntimeCore to exclude React-RuntimeHermes headers
    core_modulemap = File.join(
      installer.sandbox.root,
      'Target Support Files/React-RuntimeCore/React-RuntimeCore.modulemap'
    )
    if File.exist?(core_modulemap)
      content = File.read(core_modulemap)
      if content.include?('exclude header "React-jsitooling-umbrella.h"') && !content.include?('exclude header "React-RuntimeHermes-umbrella.h"')
        File.write(core_modulemap, content.sub('exclude header "React-jsitooling-umbrella.h"', 'exclude header "React-jsitooling-umbrella.h"' + "\n  exclude header \"React-RuntimeHermes-umbrella.h\""))
      end
    end

    # Some RN pods (and their transitive headers) can trigger
    # "non-modular-include-in-framework-module" when frameworks/modules are enabled.
    # Allowing non-modular includes prevents these builds from failing with -Werror.
    installer.pods_project.targets.each do |target|
      target.build_configurations.each do |build_config|
        build_config.build_settings['CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES'] = 'YES'
        # Fix deployment target for Xcode 15+
        build_config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.5'
        build_config.build_settings['ENABLE_USER_SCRIPT_SANDBOXING'] = 'NO'
      end
    end
  end
end
